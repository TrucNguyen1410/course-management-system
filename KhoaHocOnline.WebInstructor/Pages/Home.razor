@page "/"
@using KhoaHocOnline.WebAdmin.Services
@using KhoaHocOnline.WebAdmin.Models.DTOs
@inject CourseService CourseService
@inject CategoryService CategoryService
@inject NavigationManager Navigation
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<div class="container mt-4">
    
    <div class="row justify-content-center mb-4">
        <div class="col-md-6">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white text-primary border-end-0">
                    <i class="bi bi-search"></i>
                </span>
                <input @bind="keyword" 
                       @bind:event="oninput" 
                       @onkeyup="ApplyFilter" 
                       type="text" 
                       class="form-control border-start-0 ps-0" 
                       placeholder="Tìm kiếm khóa học quản lý..." />
            </div>
        </div>
    </div>

    <div class="d-flex flex-wrap justify-content-center gap-2 mb-4">
        <button class="btn @(selectedCategoryId == 0 ? "btn-warning text-white fw-bold" : "btn-primary")"
                @onclick="() => FilterByCategory(0)">
            Tất cả
        </button>

        @if (categories != null)
        {
            @foreach (var cat in categories)
            {
                <button class="btn @(selectedCategoryId == cat.CategoryID ? "btn-warning text-white fw-bold" : "btn-primary")"
                        @onclick="() => FilterByCategory(cat.CategoryID)">
                    @cat.CategoryName
                </button>
            }
        }
    </div>

    @if (filteredCourses == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Đang tải dữ liệu...</p>
        </div>
    }
    else if (filteredCourses.Count == 0)
    {
        <div class="text-center mt-5 text-muted">
            <i class="bi bi-inbox fs-1"></i>
            <p>Không tìm thấy khóa học nào.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var item in filteredCourses)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 course-card" style="cursor: pointer;" 
                         @onclick="() => ViewDetail(item.CourseID)">
                        
                        <div class="position-relative">
                            <img src="@(string.IsNullOrEmpty(item.ThumbnailURL) ? "https://via.placeholder.com/300x180?text=No+Image" : item.ThumbnailURL)" 
                                 class="card-img-top" alt="@item.Title" 
                                 style="height: 180px; object-fit: cover;">
                            
                            <span class="badge bg-primary position-absolute bottom-0 start-0 m-2">
                                @(item.Category?.CategoryName ?? "Chung")
                            </span>
                        </div>
                        
                        <div class="card-body d-flex flex-column">
                            <div class="mb-2">
                                <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Công cụ ôn luyện</small>
                            </div>

                            <h6 class="card-title text-dark fw-bold text-truncate-2 mb-3" title="@item.Title">
                                @item.Title
                            </h6>

                            <div class="mt-auto d-flex align-items-center">
                                <i class="bi bi-star-fill text-warning small me-1"></i>
                                <span class="fw-bold small text-muted">4.5</span>
                                <span class="small text-muted ms-1">(120 đánh giá)</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .course-card:hover {
        transform: translateY(-5px);
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 40px;
    }
    /* Style nút bấm giống User */
    .btn-primary { background-color: #004085; border: none; }
    .btn-warning { background-color: #f68b1f; border: none; color: white !important; }
</style>

@code {
    // 2 Biến lưu danh sách: 1 cái gốc, 1 cái để hiển thị (đã lọc)
    private List<CourseDto>? allCourses; 
    private List<CourseDto>? filteredCourses;
    
    private List<CategoryDto>? categories;
    
    // Biến lưu trạng thái lọc
    private int selectedCategoryId = 0;
    private string keyword = "";

    protected override async Task OnInitializedAsync()
    {
        // Gọi song song API lấy Khóa học và Danh mục
        var taskCourses = CourseService.GetCourses();
        var taskCategories = CategoryService.GetCategories();

        await Task.WhenAll(taskCourses, taskCategories);

        allCourses = await taskCourses;
        categories = await taskCategories;
        
        // Ban đầu hiển thị tất cả
        filteredCourses = allCourses;
    }

    // 1. Hàm chọn danh mục
    private void FilterByCategory(int categoryId)
    {
        selectedCategoryId = categoryId;
        ApplyFilter();
    }

    // 2. Hàm xử lý logic lọc chung (Kết hợp cả Danh mục và Từ khóa)
    private void ApplyFilter()
    {
        var temp = allCourses;

        // Lọc theo Danh mục
        if (selectedCategoryId != 0)
        {
            temp = temp?.Where(c => c.CategoryID == selectedCategoryId).ToList();
        }

        // Lọc theo Từ khóa (Tìm kiếm)
        if (!string.IsNullOrWhiteSpace(keyword))
        {
            temp = temp?.Where(c => c.Title.Contains(keyword, StringComparison.OrdinalIgnoreCase)).ToList();
        }

        filteredCourses = temp;
    }

    private void ViewDetail(int id)
    {
        Navigation.NavigateTo($"course-detail/{id}");
    }
}