@page "/my-courses"
@using KhoaHocOnline.WebUser.Services
@using KhoaHocOnline.WebUser.Models.DTOs
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using KhoaHocOnline.WebUser.Layout 
@inject CourseService CourseService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout MainLayout

<div class="container mt-5 mb-5">
    <div class="d-flex align-items-center mb-4 border-bottom pb-3">
        <div class="bg-primary text-white rounded p-2 me-3">
            <i class="bi bi-mortarboard-fill fs-4"></i>
        </div>
        <div>
            <h3 class="fw-bold text-primary mb-0">KHÓA HỌC CỦA TÔI</h3>
            <small class="text-muted">Danh sách các khóa học bạn đã sở hữu</small>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Đang tải dữ liệu...</p>
        </div>
    }
    else if (myCourses == null || myCourses.Count == 0)
    {
        <div class="text-center py-5 bg-light rounded border border-dashed">
            <i class="bi bi-journal-x fs-1 text-muted opacity-50"></i>
            <h5 class="text-muted mt-3">Bạn chưa có khóa học nào.</h5>
            <button class="btn btn-primary mt-3 fw-bold px-4 rounded-pill" @onclick='() => Navigation.NavigateTo("/")'>
                <i class="bi bi-search me-2"></i>Tìm khóa học ngay
            </button>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var item in myCourses)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 overflow-hidden">
                        <div class="position-relative">
                            <img src="@(string.IsNullOrEmpty(item.ThumbnailURL) ? "https://via.placeholder.com/300x180?text=Course" : item.ThumbnailURL)" 
                                 class="card-img-top" alt="@item.Title" style="height: 180px; object-fit: cover;">
                            
                            @if (item.IsPaid)
                            {
                                <span class="badge bg-success position-absolute top-0 end-0 m-2 shadow-sm">
                                    <i class="bi bi-check-circle-fill me-1"></i>Đã kích hoạt
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2 shadow-sm">
                                    <i class="bi bi-hourglass-split me-1"></i>Chờ duyệt
                                </span>
                            }
                        </div>
                        
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold text-dark text-truncate" title="@item.Title">@item.Title</h5>
                            
                            <p class="card-text text-muted small mb-3">
                                <i class="bi bi-calendar-event me-1"></i>Ngày đăng ký: @item.EnrollmentDate.ToString("dd/MM/yyyy")
                            </p>
                            
                            <div class="mt-auto">
                                @if (item.IsPaid)
                                {
                                    <button class="btn btn-primary w-100 fw-bold py-2" 
                                            @onclick='() => Navigation.NavigateTo($"course-learning/{item.CourseID}")'>
                                        <i class="bi bi-play-circle-fill me-2"></i>VÀO HỌC NGAY
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-light w-100 fw-bold text-muted border" disabled>
                                        <i class="bi bi-lock-fill me-2"></i>Đang chờ Admin duyệt
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<MyCourseDto>? myCourses;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            var userId = user.FindFirst("UserId")?.Value;
            if (userId != null)
            {
                myCourses = await CourseService.GetMyCourses(userId);
            }
        }
        isLoading = false;
    }
}