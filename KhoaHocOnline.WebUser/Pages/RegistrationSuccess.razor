@page "/registration-success/{courseId:int}"
@using KhoaHocOnline.WebUser.Services
@using KhoaHocOnline.WebUser.Models.DTOs
@using KhoaHocOnline.WebUser.Layout 
@using Microsoft.AspNetCore.Components.Authorization 
@inject CourseService CourseService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout RegistrationLayout

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-3 text-center p-4">
                
                <div class="mb-4 mt-3">
                    <div class="d-inline-flex align-items-center justify-content-center bg-success bg-opacity-10 rounded-circle" style="width: 80px; height: 80px;">
                        <i class="bi bi-check-lg text-success display-4"></i>
                    </div>
                </div>

                <h2 class="fw-bold text-success mb-3">ĐĂNG KÝ THÀNH CÔNG!</h2>
                <p class="text-muted mb-4">
                    Cảm ơn bạn đã tin tưởng và lựa chọn <strong>EduPro Online</strong>.<br>
                    Hồ sơ đăng ký của bạn đã được ghi nhận.
                </p>

                <div class="bg-light rounded p-3 text-start mb-4 border">
                    <h6 class="fw-bold text-primary border-bottom pb-2 mb-3">
                        <i class="bi bi-receipt me-2"></i>THÔNG TIN ĐƠN HÀNG
                    </h6>
                    
                    @if (enrollmentInfo == null)
                    {
                        <div class="text-center py-3">
                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                            <span class="ms-2 text-muted">Đang tải hóa đơn...</span>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Khóa học:</span>
                            <span class="fw-bold text-dark text-end" style="max-width: 60%;">@enrollmentInfo.CourseTitle</span>
                        </div>
                        
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Học viên:</span>
                            <span class="fw-bold text-dark">@enrollmentInfo.StudentName</span>
                        </div>

                        <hr class="my-2 border-secondary opacity-25">

                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Giá gốc:</span>
                            <span class="text-decoration-line-through text-muted">
                                @enrollmentInfo.OriginalPrice.ToString("#,##0") đ
                            </span>
                        </div>

                        @if (enrollmentInfo.PricePaid < enrollmentInfo.OriginalPrice)
                        {
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-success fst-italic">Voucher giảm giá:</span>
                                <span class="text-success fw-bold">
                                    - @((enrollmentInfo.OriginalPrice - enrollmentInfo.PricePaid).ToString("#,##0")) đ
                                </span>
                            </div>
                        }

                        <div class="d-flex justify-content-between mt-2 pt-2 border-top border-secondary border-opacity-25">
                            <span class="fw-bold text-dark fs-5">THANH TOÁN:</span>
                            <span class="fw-bold text-danger fs-4">
                                @enrollmentInfo.PricePaid.ToString("#,##0") đ
                            </span>
                        </div>
                    }
                </div>

                @if (enrollmentInfo != null && enrollmentInfo.PricePaid > 0)
                {
                    <div class="bg-white border border-success rounded p-3 mb-4 text-center shadow-sm">
                        <h5 class="fw-bold text-success mb-2"><i class="bi bi-qr-code-scan me-2"></i>QUÉT MÃ THANH TOÁN</h5>
                        <p class="small text-muted mb-3">Sử dụng App Ngân hàng để quét mã bên dưới</p>
                        
                        <img src="@($"https://img.vietqr.io/image/VCB-9338493544-compact2.png?amount={enrollmentInfo.PricePaid}&addInfo=HOCPHI {enrollmentInfo.EnrollmentID}")" 
                             class="img-fluid border rounded" 
                             style="max-width: 100%; width: 250px;" 
                             alt="QR Payment" />
                        
                        <div class="mt-3 bg-light p-2 rounded text-start small">
                            <div>Ngân hàng: <strong>Vietcombank (VCB)</strong></div>
                            <div>Số tài khoản: <strong>9338493544</strong></div>
                            <div>Nội dung: <strong class="text-primary">HOCPHI @enrollmentInfo.EnrollmentID</strong></div>
                        </div>
                    </div>
                }

                <div class="alert alert-warning d-flex align-items-start text-start" role="alert">
                    <i class="bi bi-telephone-fill me-2 fs-5 mt-1 text-warning"></i>
                    <div>
                        <strong>Cần hỗ trợ ngay?</strong> <br/>
                        Nếu gặp khó khăn khi thanh toán, vui lòng gọi Hotline: <br/>
                        <a href="tel:19002099" class="fw-bold text-danger text-decoration-none fs-5">1900 2099</a>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button class="btn btn-primary py-2 fw-bold" @onclick='() => Navigation.NavigateTo("/")'>
                        <i class="bi bi-house-door-fill me-2"></i> Về Trang Chủ
                    </button>
                </div>

            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int CourseId { get; set; }
    private EnrollmentSuccessDto? enrollmentInfo;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            var userId = user.FindFirst("UserId")?.Value;
            if (userId != null)
            {
                enrollmentInfo = await CourseService.GetLatestEnrollment(userId, CourseId);
            }
        }
    }
}