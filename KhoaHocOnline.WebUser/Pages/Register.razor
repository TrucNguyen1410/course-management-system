@page "/register"
@using KhoaHocOnline.WebUser.Services
@using KhoaHocOnline.WebUser.Models.DTOs
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
    <div class="card p-4 shadow-sm" style="width: 450px;">
        <h3 class="text-center text-success fw-bold mb-4">ĐĂNG KÝ TÀI KHOẢN</h3>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger text-center">@errorMessage</div>
        }

        <div class="mb-3">
            <label class="form-label">Họ và Tên</label>
            <input @bind="registerModel.FullName" class="form-control" placeholder="Nguyễn Văn A" />
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input @bind="registerModel.Email" class="form-control" placeholder="email@example.com" />
        </div>

        <div class="mb-3">
            <label class="form-label">Số điện thoại</label>
            <input @bind="registerModel.PhoneNumber" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Mật khẩu</label>
            <input @bind="registerModel.Password" type="password" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Nhập lại mật khẩu</label>
            <input @bind="registerModel.ConfirmPassword" type="password" class="form-control" />
        </div>

        <button class="btn btn-success w-100 fw-bold" @onclick="HandleRegister">Đăng Ký</button>

        <div class="text-center mt-3">
            <a href="login" class="text-decoration-none">Đã có tài khoản? Đăng nhập</a>
        </div>
    </div>
</div>

@code {
    private RegisterDto registerModel = new RegisterDto();
    private string? errorMessage;

    private async Task HandleRegister()
    {
        if (registerModel.Password != registerModel.ConfirmPassword)
        {
            errorMessage = "Mật khẩu nhập lại không khớp!";
            return;
        }

        // SỬA LỖI TẠI ĐÂY: Hứng kết quả là Object chứ không phải bool
        var result = await AuthService.Register(registerModel);

        if (result.IsSuccess)
        {
            // Đăng ký thành công -> Chuyển về trang đăng nhập
            Navigation.NavigateTo("login");
        }
        else
        {
            errorMessage = result.ErrorMessage ?? "Đăng ký thất bại.";
        }
    }
}