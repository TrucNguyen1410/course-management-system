@inherits LayoutComponentBase
@using KhoaHocOnline.WebUser.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top" style="z-index: 1030;">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <span class="fs-4 fw-bold text-primary text-uppercase" style="letter-spacing: 1px;">
                    <i class="bi bi-mortarboard-fill me-2"></i>EduPro Online
                </span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
                    <AuthorizeView>
                        <Authorized>
                            <li class="nav-item dropdown position-relative">
                                <button class="btn btn-outline-primary fw-bold d-flex align-items-center dropdown-toggle px-3 rounded-pill" 
                                        @onclick="ToggleUserMenu">
                                    <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-2" 
                                         style="width: 30px; height: 30px;">
                                        <span class="small">@context.User.Identity?.Name?.Substring(0, 1).ToUpper()</span>
                                    </div>
                                    <span class="text-truncate" style="max-width: 150px;">Xin chào, @context.User.Identity?.Name</span>
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 @(showUserMenu ? "show" : "")" 
                                    style="right: 0; left: auto; position: absolute; min-width: 200px;">
                                    
                                    <li>
                                        <a class="dropdown-item py-2" href="/" @onclick="CloseMenu">
                                            <i class="bi bi-house-door me-2 text-primary"></i>Trang chủ
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item py-2" href="my-courses" @onclick="CloseMenu">
                                            <i class="bi bi-journal-bookmark-fill me-2 text-warning"></i>Khóa học của tôi
                                        </a>
                                    </li>
                                    
                                    <li><hr class="dropdown-divider"></li>
                                    
                                    <li>
                                        <button class="dropdown-item py-2 text-danger fw-bold" @onclick="HandleLogout">
                                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                        </button>
                                    </li>
                                </ul>
                            </li>
                        </Authorized>
                        
                        <NotAuthorized>
                            <li class="nav-item me-2">
                                <a href="login" class="btn btn-outline-primary fw-bold rounded-pill px-4">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a href="register" class="btn btn-primary fw-bold rounded-pill px-4">Đăng ký</a>
                            </li>
                        </NotAuthorized>
                    </AuthorizeView>
                </ul>
            </div>
        </div>
    </nav>

    <main class="flex-grow-1 bg-light">
        @Body
    </main>

    <footer class="bg-dark text-white py-4 mt-auto">
        <div class="container text-center">
            <h5 class="fw-bold text-uppercase mb-3">EduPro Online</h5>
            <p class="text-white-50 small mb-0">&copy; 2024 EduPro Online. Nền tảng học trực tuyến hàng đầu.</p>
        </div>
    </footer>
</div>

@code {
    private bool showUserMenu = false;

    private void ToggleUserMenu()
    {
        showUserMenu = !showUserMenu;
    }

    private void CloseMenu()
    {
        showUserMenu = false;
    }

    private async Task HandleLogout()
    {
        showUserMenu = false;
        await AuthService.Logout();
        Navigation.NavigateTo("/", true);
    }
}