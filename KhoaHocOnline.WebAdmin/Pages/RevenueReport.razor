@page "/revenue-report"
@using KhoaHocOnline.WebAdmin.Services
@using KhoaHocOnline.WebAdmin.Models.DTOs
@inject EnrollmentService EnrollmentService
@inject IJSRuntime JSRuntime
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<div class="container mt-4">
    <h3 class="text-primary fw-bold mb-4">Báo Cáo Doanh Thu & Hiệu Quả</h3>

    @if (reportData == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Đang tổng hợp số liệu...</p>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card text-white bg-primary shadow h-100 border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title text-uppercase mb-0 opacity-75">Tổng Doanh Thu</h6>
                                <h2 class="fw-bold my-2">@reportData.TotalRevenue.ToString("#,##0") đ</h2>
                            </div>
                            <i class="bi bi-currency-dollar display-4 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card text-white bg-success shadow h-100 border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title text-uppercase mb-0 opacity-75">Đơn Hàng Thành Công</h6>
                                <h2 class="fw-bold my-2">@reportData.TotalOrders</h2>
                            </div>
                            <i class="bi bi-cart-check-fill display-4 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card text-white bg-warning shadow h-100 border-0 voucher-card" 
                     @onclick="OpenVoucherModal" 
                     style="cursor: pointer;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title text-uppercase mb-0 opacity-75 text-dark">Lượt Dùng Voucher</h6>
                                <h2 class="fw-bold my-2 text-dark">@reportData.TotalVouchersUsed</h2>
                                <small class="text-dark fw-bold text-decoration-underline fst-italic">Xem chi tiết >></small>
                            </div>
                            <i class="bi bi-ticket-perforated-fill display-4 text-dark opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white fw-bold py-3">
                        <i class="bi bi-graph-up-arrow me-2 text-primary"></i>Biểu đồ tăng trưởng doanh thu
                    </div>
                    <div class="card-body">
                        <canvas id="revenueChart" style="max-height: 350px;"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white fw-bold py-3">
                        <i class="bi bi-pie-chart-fill me-2 text-info"></i>Tỷ trọng theo Danh mục
                    </div>
                    <div class="card-body d-flex justify-content-center align-items-center">
                        <canvas id="categoryChart" style="max-height: 300px;"></canvas>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-ticket-perforated-fill me-2"></i>Danh Sách Sử Dụng Voucher
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body p-0">
                    @if (reportData?.VoucherDetails == null || reportData.VoucherDetails.Count == 0)
                    {
                        <div class="p-5 text-center text-muted">
                            <i class="bi bi-inbox fs-1"></i>
                            <p class="mt-2">Chưa có dữ liệu.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover mb-0 align-middle">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Học viên</th>
                                        <th>Khóa học</th>
                                        <th class="text-end">Giá gốc</th>
                                        <th class="text-end">Đã trả</th>
                                        <th class="text-end">Tiết kiệm</th>
                                        <th class="text-center">Ngày mua</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in reportData.VoucherDetails)
                                    {
                                        <tr>
                                            <td class="fw-bold text-primary">@item.StudentName</td>
                                            <td>@item.CourseName</td>
                                            <td class="text-end text-decoration-line-through text-muted">@item.OriginalPrice.ToString("#,##0")</td>
                                            <td class="text-end fw-bold text-success">@item.PaidPrice.ToString("#,##0")</td>
                                            <td class="text-end text-danger fw-bold">-@((item.OriginalPrice - item.PaidPrice).ToString("#,##0"))</td>
                                            <td class="text-center">@item.Date.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Đóng</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .voucher-card:hover {
        transform: translateY(-5px);
        transition: transform 0.2s ease;
    }
</style>

@code {
    private ReportDto? reportData;
    private bool showModal = false;

    protected override async Task OnInitializedAsync()
    {
        reportData = await EnrollmentService.GetReportStats();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (reportData != null)
        {
            await JSRuntime.InvokeVoidAsync("renderCharts", reportData.RevenueByMonth, reportData.RevenueByCategory);
        }
    }

    private void OpenVoucherModal()
    {
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }
}